{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "Translations",
      "description": "Recipe step discriminator. Must be \u0027Translations\u0027."
    },
    "translations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "culture": {
            "type": "string",
            "description": "Culture name, for example \u0027en-US\u0027 or \u0027fr\u0027."
          },
          "context": {
            "type": "string",
            "description": "Optional translation context used to disambiguate the key."
          },
          "key": {
            "type": "string",
            "description": "Localization key to translate."
          },
          "value": {
            "type": "string",
            "description": "Localized value stored for the key."
          }
        },
        "required": [
          "culture",
          "key"
        ],
        "additionalProperties": true,
        "description": "Single localization entry."
      },
      "minItems": 1,
      "description": "Translation entries to import."
    }
  },
  "required": [
    "name",
    "translations"
  ],
  "additionalProperties": true
}