{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "AIDeployment"
    },
    "Deployments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Deployment name as specified by the vendor."
          },
          "ProviderName": {
            "type": "string",
            "description": "Provider name (e.g., OpenAI, DeepSeek)."
          },
          "ConnectionName": {
            "type": "string",
            "description": "Connection name used to configure the provider."
          },
          "Type": {
            "anyOf": [
              {
                "type": "string",
                "description": "The deployment type, or a comma-separated flag value such as \u0027Chat, Utility\u0027. Defaults to Chat when not specified."
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "Chat",
                    "Utility",
                    "Embedding",
                    "Image",
                    "SpeechToText",
                    "TextToSpeech"
                  ]
                },
                "minItems": 1,
                "uniqueItems": true,
                "description": "The deployment types."
              }
            ]
          },
          "IsDefault": {
            "type": "boolean",
            "description": "Whether this deployment is the default for its type and connection."
          }
        },
        "required": [
          "Name"
        ],
        "additionalProperties": true
      },
      "minItems": 1,
      "description": "The AI deployments to create or update."
    }
  },
  "required": [
    "name",
    "Deployments"
  ],
  "additionalProperties": true
}