{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "Queries",
      "description": "Recipe step discriminator. Must be \u0027Queries\u0027."
    },
    "Queries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Unique query name."
          },
          "Source": {
            "type": "string",
            "description": "Query source provider, such as Sql, Lucene, or Elasticsearch."
          },
          "Schema": {
            "type": "string",
            "description": "Optional schema or projection payload consumed by the source provider."
          },
          "Template": {
            "type": "string",
            "description": "Raw query text or template executed by the source provider."
          },
          "ReturnContentItems": {
            "type": "boolean",
            "description": "Whether the query returns full content items instead of primitive results."
          }
        },
        "required": [
          "Name",
          "Source"
        ],
        "additionalProperties": true
      },
      "minItems": 1,
      "description": "Queries to create or update."
    }
  },
  "required": [
    "name",
    "Queries"
  ],
  "additionalProperties": true
}