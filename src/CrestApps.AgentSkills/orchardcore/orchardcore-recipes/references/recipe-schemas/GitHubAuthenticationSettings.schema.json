  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "GitHubAuthenticationSettings",
      "description": "Recipe step discriminator. Must be \u0027GitHubAuthenticationSettings\u0027."
    },
    "ConsumerKey": {
      "type": "string",
      "description": "GitHub OAuth application client ID."
    },
    "ConsumerSecret": {
      "type": "string",
