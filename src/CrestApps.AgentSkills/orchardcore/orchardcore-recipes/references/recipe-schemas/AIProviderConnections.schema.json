{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "AIProviderConnections",
      "description": "Recipe step discriminator. Must be \u0027AIProviderConnections\u0027."
    },
    "Connections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ItemId": {
            "type": "string",
            "description": "Optional unique identifier."
          },
          "Source": {
            "type": "string",
            "description": "Connection source/provider identifier for the registered AI provider."
          },
          "Name": {
            "type": "string",
            "description": "Unique connection name."
          },
          "DisplayText": {
            "type": "string",
            "description": "Display name."
          },
          "ClientName": {
            "type": "string",
            "description": "Obsolete alias for Source kept for backward compatibility."
          },
          "Endpoint": {
            "type": "string",
            "description": "Common connection endpoint alias for recipe imports."
          },
          "AuthenticationType": {
            "type": "string",
            "enum": [
              "Default",
              "ManagedIdentity",
              "ApiKey"
            ],
            "description": "Common Azure connection authentication type alias for recipe imports."
          },
          "ApiKey": {
            "type": "string",
            "description": "Common connection API key alias for recipe imports."
          },
          "IdentityId": {
            "type": "string",
            "description": "Common Azure connection managed identity client ID alias for recipe imports."
          },
          "Properties": {
            "type": "object",
            "properties": {
              "OpenAIConnectionMetadata": {
                "type": "object",
                "properties": {
                  "Endpoint": {
                    "type": "string",
                    "description": "Provider API endpoint."
                  },
                  "ApiKey": {
                    "type": "string",
                    "description": "Provider API key."
                  }
                },
                "additionalProperties": true,
                "description": "Metadata for OpenAI-compatible connections."
              },
              "AzureConnectionMetadata": {
                "type": "object",
                "properties": {
                  "Endpoint": {
                    "type": "string",
                    "description": "Provider API endpoint."
                  },
                  "AuthenticationType": {
                    "type": "string",
                    "enum": [
                      "Default",
                      "ManagedIdentity",
                      "ApiKey"
                    ],
                    "description": "Azure authentication type. Supported values are Default, ManagedIdentity, or ApiKey."
                  },
                  "ApiKey": {
                    "type": "string",
                    "description": "Provider API key. Required when AuthenticationType is ApiKey."
                  },
                  "IdentityId": {
                    "type": "string",
                    "description": "Optional client ID of a user-assigned managed identity. Used when AuthenticationType is ManagedIdentity."
                  }
                },
                "additionalProperties": true,
                "description": "Metadata for Azure AI Inference connections."
              },
              "AzureOpenAIConnectionMetadata": {
                "type": "object",
                "properties": {
                  "Endpoint": {
                    "type": "string",
                    "description": "Provider API endpoint."
                  },
                  "AuthenticationType": {
                    "type": "string",
                    "enum": [
                      "Default",
                      "ManagedIdentity",
                      "ApiKey"
                    ],
                    "description": "Azure authentication type. Supported values are Default, ManagedIdentity, or ApiKey."
                  },
                  "ApiKey": {
                    "type": "string",
                    "description": "Provider API key. Required when AuthenticationType is ApiKey."
                  },
                  "IdentityId": {
                    "type": "string",
                    "description": "Optional client ID of a user-assigned managed identity. Used when AuthenticationType is ManagedIdentity."
                  }
                },
                "additionalProperties": true,
                "description": "Metadata for Azure AI Inference connections."
              },
              "AzureAIInferenceConnectionMetadata": {
                "type": "object",
                "properties": {
                  "Endpoint": {
                    "type": "string",
                    "description": "Provider API endpoint."
                  },
                  "AuthenticationType": {
                    "type": "string",
                    "enum": [
                      "Default",
                      "ManagedIdentity",
                      "ApiKey"
                    ],
                    "description": "Azure authentication type. Supported values are Default, ManagedIdentity, or ApiKey."
                  },
                  "ApiKey": {
                    "type": "string",
                    "description": "Provider API key. Required when AuthenticationType is ApiKey."
                  },
                  "IdentityId": {
                    "type": "string",
                    "description": "Optional client ID of a user-assigned managed identity. Used when AuthenticationType is ManagedIdentity."
                  }
                },
                "additionalProperties": true,
                "description": "Metadata for Azure AI Inference connections."
              }
            },
            "additionalProperties": true,
            "description": "Provider-specific connection metadata grouped by metadata object name."
          }
        },
        "required": [
          "Name"
        ],
        "additionalProperties": true
      },
      "minItems": 1,
      "description": "The AI provider connections to create or update."
    }
  },
  "required": [
    "name",
    "Connections"
  ],
  "additionalProperties": true
}