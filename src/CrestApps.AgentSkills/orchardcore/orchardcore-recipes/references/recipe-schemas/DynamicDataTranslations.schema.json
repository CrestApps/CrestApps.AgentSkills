{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "const": "DynamicDataTranslations",
      "description": "Recipe step discriminator. Must be \u0027DynamicDataTranslations\u0027."
    },
    "Translations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Logical translation set name."
          },
          "Translation": {
            "type": "object",
            "properties": {
              "Context": {
                "type": "string",
                "description": "Optional localization context used to disambiguate the translation key."
              },
              "Key": {
                "type": "string",
                "description": "Translation key to replace or add."
              },
              "Value": {
                "type": "string",
                "description": "Localized value to store for the key."
              }
            },
            "required": [
              "Key"
            ],
            "additionalProperties": true,
            "description": "Translation entry payload."
          }
        },
        "required": [
          "Name",
          "Translation"
        ],
        "additionalProperties": true,
        "description": "A named dynamic-data translation entry."
      },
      "minItems": 1,
      "description": "Dynamic data translation entries to import."
    }
  },
  "required": [
    "name",
    "Translations"
  ],
  "additionalProperties": true
}