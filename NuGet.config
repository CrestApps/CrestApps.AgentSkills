<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
		<add key="CrestAppsCorePreview" value="https://nuget.cloudsmith.io/crestapps/crestapps-core/v3/index.json" />
	</packageSources>

	<packageSourceMapping>

		<packageSource key="CrestAppsCorePreview">
			<package pattern="CrestApps.Core" />
			<package pattern="CrestApps.Core*" />
		</packageSource>

		<packageSource key="nuget.org">
			<package pattern="*" />
		</packageSource>

	</packageSourceMapping>

</configuration>
